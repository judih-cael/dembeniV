# ═══════════════════════════════════════════════════════════════
#  CONFIGURATION DE L'ENVIRONNEMENT — Portail Citoyen Dembéni
# ═══════════════════════════════════════════════════════════════

# Port du serveur de développement local
PORT=4000

# Environnement (development / production)
NODE_ENV=development

# URI de connexion à la base de données MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Clé secrète pour la génération des tokens JWT
JWT_SECRET=votre_cle_secrete_longue_et_securisee

# Configuration du service SMTP de messagerie (ex: Gmail)
SMTP_USER=votre_adresse_email@gmail.com
SMTP_PASS=votre_mot_de_passe_d_application_sans_espaces

# Configuration Cloudinary (Recommandé pour la persistance des images sur Vercel)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
